# =============================================================================
# QNAP NAS Automation — Inventory Example
# =============================================================================
# Copy this file to a file named "inventory" and fill in your values.
# Never commit your real inventory — add it to .gitignore.
#
# Two connection modes are supported:
#   Local (LAN)  — use 192.168.x.x IPs when on the same network
#   Remote       — use Tailscale IPs (100.x.x.x) when away from home
#
# To switch modes, change ansible_host to the appropriate IP,
# or maintain two groups as shown below and use --limit when running.
# =============================================================================

# ---- Local Network ----
[nas]
my-qnap-nas  ansible_host=192.168.1.100   # Replace with your NAS local IP

# ---- Tailscale (Remote) ----
[tailscale_nas]
my-qnap-nas  ansible_host=100.x.x.x       # Replace with your NAS Tailscale IP

# ---- Group Variables ----
[nas:vars]
ansible_user=admin                         # Default QNAP admin account
ansible_python_interpreter=/bin/false      # QNAP uses BusyBox — no Python

[tailscale_nas:vars]
ansible_user=admin
ansible_python_interpreter=/bin/false

# =============================================================================
# Quick connectivity test:
#   ansible nas -m ping -i inventory
# =============================================================================
