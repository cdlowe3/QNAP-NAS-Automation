# =============================================================================
# QNAP NAS Inventory Example
# =============================================================================
# This is a sanitized example inventory for QNAP NAS automation playbooks.
# Replace the values below with your actual environment details.

[nas]
192.168.1.100    # Replace with your QNAP NAS IP address

[nas:vars]
ansible_user=your_nas_username          # Replace with your NAS admin username
ansible_python_interpreter=/bin/false   # Required for QNAP systems without Python

[other_devices]
# Example of other devices in your environment
192.168.1.10     # Example: Raspberry Pi
192.168.1.20     # Example: Linux server

[all:vars]
ansible_user=your_username              # Default username for other devices
ansible_python_interpreter=/usr/bin/python3

# =============================================================================
# Setup Instructions:
# 1. Replace IP addresses with your actual device IPs
# 2. Update usernames to match your environment
# 3. Ensure SSH key authentication is configured
# 4. Test connectivity: ansible nas -m ping
# =============================================================================